generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  CHECKING
  SAVINGS
  INVESTMENT
  RETIREMENT
  CREDIT
}

enum AssetCategory {
  CASH
  EQUITY
  BOND
  REAL_ESTATE
  CRYPTO
  OTHER
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  INVESTMENT
}

enum VisibilityScope {
  PERSONAL
  SHARED
}

model User {
  id                  String              @id @default(cuid())
  name                String?
  email               String              @unique
  emailVerified       DateTime?
  image               String?
  passwordHash        String?
  ownedAccounts       Account[]           @relation("OwnedAccounts")
  ownedAssets         Asset[]             @relation("OwnedAssets")
  ownedTransactions   Transaction[]       @relation("OwnedTransactions")
  ownedGoals          Goal[]              @relation("OwnedGoals")
  sessions            Session[]
  authAccounts        AuthAccount[]
  householdMemberships HouseholdMember[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model Household {
  id           String            @id @default(cuid())
  name         String
  members      HouseholdMember[]
  accounts     Account[]
  assets       Asset[]
  transactions Transaction[]
  goals        Goal[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model HouseholdMember {
  id          String    @id @default(cuid())
  householdId String
  userId      String
  role        String    @default("member")
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([householdId, userId])
}

model AuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Account {
  id           String          @id @default(cuid())
  householdId  String
  ownerUserId  String?
  visibility   VisibilityScope @default(PERSONAL)
  name         String
  institution  String
  balance      Decimal
  currency     String          @default("EUR")
  type         AccountType
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  household    Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  ownerUser    User?           @relation("OwnedAccounts", fields: [ownerUserId], references: [id], onDelete: SetNull)
  assets       Asset[]
  transactions Transaction[]
}

model Asset {
  id             String          @id @default(cuid())
  householdId    String
  ownerUserId    String?
  accountId      String?
  visibility     VisibilityScope @default(PERSONAL)
  name           String
  category       AssetCategory
  value          Decimal
  costBasis      Decimal?
  performancePct Decimal?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  household      Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  ownerUser      User?           @relation("OwnedAssets", fields: [ownerUserId], references: [id], onDelete: SetNull)
  account        Account?        @relation(fields: [accountId], references: [id], onDelete: SetNull)
}

model Transaction {
  id          String          @id @default(cuid())
  householdId String
  ownerUserId String?
  accountId   String?
  visibility  VisibilityScope @default(PERSONAL)
  label       String
  amount      Decimal
  type        TransactionType
  category    String
  occurredAt  DateTime
  note        String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  household   Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  ownerUser   User?           @relation("OwnedTransactions", fields: [ownerUserId], references: [id], onDelete: SetNull)
  account     Account?        @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([householdId, occurredAt])
}

model Goal {
  id          String          @id @default(cuid())
  householdId String
  ownerUserId String?
  visibility  VisibilityScope @default(PERSONAL)
  name        String
  target      Decimal
  current     Decimal
  deadline    DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  household   Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  ownerUser   User?           @relation("OwnedGoals", fields: [ownerUserId], references: [id], onDelete: SetNull)
}
